# AML Formal Grammar (EBNF)

# A document is arbitrary text interspersed with skill and directive tags.
Document       ::= (Text | SkillNode | DirectiveNode)*

# Skill nodes come in three mutually exclusive forms:
SkillNode      ::= Invocation | InterfaceDef | ImplementationDef

# --- INVOCATION ---
# At least one of: interface, impl, or name (resolution target).
# Optional: language, framework, retries, timeout.
Invocation     ::= '<skill' InvocationAttrs '>' InvocationBody '</skill>'
                 | '<skill' InvocationAttrs '/>'           # self-closing (no scope)

InvocationAttrs ::= (InterfaceAttr | ImplAttr | NameAttr) CommonAttrs*

InterfaceAttr  ::= 'interface' '=' QuotedString
ImplAttr       ::= 'impl' '=' QuotedString
NameAttr       ::= 'name' '=' QuotedString

# interface and impl MAY co-occur: runtime validates impl implements interface.
# name is mutually exclusive with interface/impl.
# At least one of (interface | impl | name) MUST be present.

CommonAttrs    ::= LanguageAttr | FrameworkAttr | RetriesAttr | TimeoutAttr
LanguageAttr   ::= 'language' '=' QuotedString
FrameworkAttr  ::= 'framework' '=' QuotedString
RetriesAttr    ::= 'retries' '=' QuotedString    # must parse as unsigned integer
TimeoutAttr    ::= 'timeout' '=' QuotedString    # must parse as duration (e.g. "30s")

InvocationBody ::= (Text | Param | SkillNode | DirectiveNode)*   # supports nesting + mixed content

# --- PARAMETERS ---
Param          ::= '<param' 'name' '=' QuotedString '>' ParamValue '</param>'
ParamValue     ::= Text                           # no nested skill tags in params

# --- INTERFACE DEFINITION ---
# define="interface" is required. name is required.
# NOT executable. Registered into SkillRegistry during definition extraction phase.
# Body may contain typed parameter declarations, return declarations,
# file I/O declarations, and free-form text (all optional).
InterfaceDef   ::= '<skill' 'define' '=' '"interface"' 'name' '=' QuotedString InterfaceDefAttrs? '>'
                     InterfaceBody
                   '</skill>'

InterfaceDefAttrs ::= DescriptionAttr?
DescriptionAttr   ::= 'description' '=' QuotedString

InterfaceBody  ::= (Text | ParamDecl | ReturnsDecl | ReadsDecl | WritesDecl | SkillRefDecl | ToolConstraintDecl)*

# --- PARAMETER DECLARATIONS (inside interface definitions) ---
# Declare a named, typed input parameter with optional default and description.
ParamDecl      ::= '<param' ParamDeclAttrs '>' Text '</param>'
                 | '<param' ParamDeclAttrs '/>'
ParamDeclAttrs ::= 'name' '=' QuotedString
                   ('type' '=' QuotedString)?        # string | enum | number | boolean | path | list
                   ('required' '=' QuotedString)?    # "true" or "false"
                   ('default' '=' QuotedString)?
                   ('values' '=' QuotedString)?      # required when type="enum"; pipe-separated

# --- RETURN DECLARATIONS (inside interface definitions) ---
ReturnsDecl    ::= '<returns' ReturnsDeclAttrs '>' Text '</returns>'
                 | '<returns' ReturnsDeclAttrs '/>'
ReturnsDeclAttrs ::= 'name' '=' QuotedString
                    ('type' '=' QuotedString)?
                    ('values' '=' QuotedString)?

# --- FILE I/O DECLARATIONS (inside interface definitions) ---
# Declare file-read or file-write patterns (comma-separated globs).
ReadsDecl      ::= '<reads>' Text '</reads>'
WritesDecl     ::= '<writes>' Text '</writes>'

# --- SKILL REFERENCE (inside interface or implementation definitions) ---
# References another skill (e.g. for DDE enforcement).
# Self-closing form: flat dependency declaration.
# Wrapping form: scoped governance — enclosed content is governed by the ref.
# In implementation bodies, <node> declarations inside wrapping refs are
# extracted into the parent implementation's nodes list.
SkillRefDecl   ::= '<skill' 'ref' '=' QuotedString SkillRefAttrs? '/>'
                 | '<skill' 'ref' '=' QuotedString SkillRefAttrs? '>' SkillRefBody '</skill>'
SkillRefAttrs  ::= 'role' '=' QuotedString
SkillRefBody   ::= (Text | NodeDecl)*           # wrapping form may contain nodes

# --- TOOL CONSTRAINT (inside interface definitions) ---
# Declares allowed/denied tools as part of the interface contract.
# Self-closing only; must have allow or deny (not both).
ToolConstraintDecl ::= '<tool' (AllowAttr | DenyAttr) '/>'

# --- IMPLEMENTATION DEFINITION ---
# define="implementation" is required. name and implements are required.
# NOT executable. Registered into SkillRegistry during definition extraction phase.
# Body may contain DDE node declarations and free-form text (e.g. mermaid flowcharts).
ImplementationDef ::= '<skill' 'define' '=' '"implementation"'
                        'name' '=' QuotedString
                        'implements' '=' QuotedString
                        ImplDefAttrs?
                      '>'
                        ImplementationBody
                      '</skill>'

ImplDefAttrs       ::= (LanguageAttr | FrameworkAttr | DescriptionAttr)*

ImplementationBody ::= (Text | NodeDecl | SkillRefDecl)*

# --- NODE DECLARATIONS (inside implementation definitions) ---
# Each node describes one step in a DDE flowchart.
# name must match the mermaid node label.
# type is "tool" (deterministic) or "prompt" (LLM reasoning).
NodeDecl       ::= '<node' NodeDeclAttrs '>' NodeBody '</node>'
NodeDeclAttrs  ::= 'name' '=' QuotedString 'type' '=' QuotedString   # "tool" or "prompt"
NodeBody       ::= (Text | ToolUseDecl)*
ToolUseDecl    ::= '<tool' 'use' '=' QuotedString '/>'               # which tool a node invokes

# --- DIRECTIVE NODES ---
# Directives instruct the runtime about execution environment.
# They are NOT skill definitions or invocations.
DirectiveNode  ::= ToolDirective | SessionDirective | AgentDirective

# --- TOOL DIRECTIVE ---
# Constrains which tools are available within the scope.
# At least one of: name, allow, deny.
# allow and deny are mutually exclusive.
ToolDirective  ::= '<tool' ToolAttrs '>' DirectiveBody '</tool>'
                 | '<tool' ToolAttrs '/>'
ToolAttrs      ::= (ToolNameAttr | AllowAttr | DenyAttr)+
ToolNameAttr   ::= 'name' '=' QuotedString
AllowAttr      ::= 'allow' '=' QuotedString       # comma-separated tool names
DenyAttr       ::= 'deny' '=' QuotedString        # comma-separated tool names

# --- SESSION DIRECTIVE ---
# Executes enclosed content in a separate session.
SessionDirective ::= '<session' SessionAttrs? '>' DirectiveBody '</session>'
                   | '<session' SessionAttrs? '/>'
SessionAttrs     ::= (SessionNameAttr | IsolatedAttr | OnFailureAttr)*
SessionNameAttr  ::= 'name' '=' QuotedString
IsolatedAttr     ::= 'isolated' '=' QuotedString  # "true" or "false"

# --- AGENT DIRECTIVE ---
# Delegates enclosed content to a subagent.
# name is required.
AgentDirective   ::= '<agent' AgentAttrs '>' DirectiveBody '</agent>'
                   | '<agent' AgentAttrs '/>'
AgentAttrs       ::= AgentNameAttr AgentOptAttrs*
AgentNameAttr    ::= 'name' '=' QuotedString
AgentOptAttrs    ::= ModelAttr | ModeAttr | OnFailureAttr
ModelAttr        ::= 'model' '=' QuotedString
ModeAttr         ::= 'mode' '=' QuotedString      # "sync" or "background"

# Directive body may contain any AML content.
DirectiveBody  ::= (Text | SkillNode | DirectiveNode)*

# Shared attribute used by invocations, sessions, and agents.
OnFailureAttr  ::= 'on-failure' '=' QuotedString  # "halt", "skip", or "partial"

# --- TOOL CONSTRAINT COMPOSITION ---
# Nested <tool> directives compose monotonically:
#   - allow-lists intersect: inner ∩ outer
#   - deny-lists union: inner ∪ outer
#   - deny always beats allow (a tool denied at any ancestor is permanently denied)
#   - inner scopes can only further restrict, never widen, the tool set

# --- ATTRIBUTE VALIDATION RULES ---
# These combinations are INVALID and must be rejected:
#   - define + interface (definition is not invocation)
#   - define + impl (definition is not invocation)
#   - define + retries (definitions don't execute)
#   - define + timeout (definitions don't execute)
#   - name + interface (name is direct lookup; use interface OR name)
#   - name + impl (name is direct lookup; use impl OR name)
#   - define="interface" without name
#   - define="implementation" without name or implements
#   - Invocation without any of: interface, impl, name
#   - <tool> with both allow and deny
#   - <tool> without any of: name, allow, deny
#   - <agent> without name
#   - Directives inside definition bodies

# --- LEXICAL RULES ---
QuotedString   ::= '"' [^"]* '"'                  # double-quoted only
                 | "'" [^']* "'"                  # single-quoted also allowed

Text           ::= [^<]+                          # any content that is not a tag open
                 | '<' (?! 'skill' | '/skill' | 'param' | '/param'
                       | 'tool' | '/tool' | 'session' | '/session'
                       | 'agent' | '/agent')       # literal '<' not part of a tag

# --- ESCAPING ---
# Within Text and ParamValue, the following escape sequences are recognised:
#   &lt;    → <
#   &gt;    → >
#   &amp;   → &
#   &quot;  → "
#   &apos;  → '
# No CDATA support. Unknown &entities; are left as-is (not an error).

# --- WHITESPACE ---
# Whitespace between attributes follows XML rules: at least one whitespace char
# separates adjacent attributes. Whitespace within Text is preserved verbatim.
# Leading/trailing whitespace in attribute values is trimmed.

# --- COMMENTS ---
# AML supports XML-style comments:
Comment        ::= '<!--' CommentContent '-->'
CommentContent ::= [^-]* | '-' [^-]+             # no '--' inside comments
# Comments are stripped during parsing and do not appear in the AST.
